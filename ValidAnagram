class Solution {
    public boolean isAnagram(String s, String t) {
        int freq[] = new int[26];
        s.toLowerCase();
        t.toLowerCase();
        char ch1[] = s.toCharArray();
        char ch2[] = t.toCharArray();
        for(char ch:ch1)
        {
            freq[ch-'a']++;
        }
        for(char ch:ch2)
        {
            freq[ch-'a']--;
        }
        for(int i:freq)
        {
            if(i!=0) return false;
        }
        return true;
    }
}
