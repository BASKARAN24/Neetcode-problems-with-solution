class Solution {
    public int[] getConcatenation(int[] nums) {
        int[] ans = new int[(nums.length*2)];
        int ind = 0;
        int count=2;
        while(count>0)
        {
            for(int i:nums)
        {
            ans[ind++] = i;
        }
        count--;
        }
        return ans;
    }
}
